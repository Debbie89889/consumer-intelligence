# Data (raw download + generated artifacts are not committed)
data/raw/*
data/processed/*
data/*.db
!data/raw/.gitkeep
!data/processed/.gitkeep
# Small derived outputs committed so the deployed service has data
# (no 95MB raw CSV / no re-running the pipeline needed in the cloud).
!data/processed/customer_segments.parquet
!data/processed/customer_clv.parquet
!data/processed/propensity_scores.parquet
!data/processed/association_rules.parquet
!data/processed/product_summary.parquet
reports/*.html

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# OS / editor
.DS_Store
.idea/
.vscode/
